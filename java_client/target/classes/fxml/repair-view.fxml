<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="root" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teach.javafx.client.controller.RepairController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header">
            <children>
                <Label styleClass="header-title" text="🏠 宿舍管理系统">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="welcomeLabel" styleClass="header-user" text="欢迎，同学">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="header-btn" text="退出登录" />
            </children>
        </HBox>
    </top>
    <left>
        <VBox spacing="5.0" styleClass="sidebar">
            <children>
                <Button fx:id="homeBtn" onAction="#showHome" prefWidth="160.0" styleClass="sidebar-btn" text="🏠 首页概览" />
                <Button fx:id="repairBtn" onAction="#showRepair" prefWidth="160.0" styleClass="sidebar-btn,active" text="🔧 我要报修" />
                <Button fx:id="profileBtn" onAction="#showProfile" prefWidth="160.0" styleClass="sidebar-btn" text="👤 个人信息" />
            </children>
        </VBox>
    </left>
    <center>
        <VBox alignment="TOP_CENTER" spacing="25.0" styleClass="content">
            <children>
                <Label text="🔧 提交报修申请" textFill="#2d3748">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <VBox maxWidth="550.0" spacing="20.0" styleClass="card">
                    <children>
                        <!-- 报修类型 -->
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="label-primary" text="报修类型 *" />
                                <ComboBox fx:id="typeCombo" prefWidth="500.0" promptText="请选择报修类型" styleClass="combo-box" />
                            </children>
                        </VBox>
                        
                        <!-- 问题描述 -->
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="label-primary" text="问题描述 *" />
                                <TextArea fx:id="descArea" prefHeight="120.0" prefWidth="500.0" promptText="请详细描述您遇到的问题，例如：水龙头漏水、灯不亮、门锁损坏等..." wrapText="true" styleClass="text-field" />
                            </children>
                        </VBox>
                        
                        <!-- 联系电话 -->
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="label-primary" text="联系电话 *" />
                                <TextField fx:id="phoneField" prefWidth="500.0" promptText="请输入您的联系电话，方便维修人员联系您" styleClass="input-field" />
                            </children>
                        </VBox>
                        
                        <!-- 错误提示 -->
                        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                        
                        <!-- 按钮 -->
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <Button fx:id="submitBtn" onAction="#handleSubmit" prefWidth="140.0" styleClass="btn-success" text="✓ 提交申请" />
                                <Button fx:id="resetBtn" onAction="#handleReset" prefWidth="140.0" styleClass="btn-secondary" text="↺ 重置" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                
                <!-- 提示信息 -->
                <HBox alignment="CENTER_LEFT" maxWidth="550.0" spacing="10" style="-fx-background-color: #e6fffa; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #38b2ac; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="💡" style="-fx-font-size: 16px;"/>
                    <Label text="提交后请耐心等待，维修人员会尽快处理您的报修申请。您可以在首页查看报修进度。" 
                           style="-fx-text-fill: #234e52; -fx-font-size: 13px;" wrapText="true"/>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
