<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="root" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.client.controller.ProfileController">
    
    <!-- 顶部标题栏 -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header">
            <Button fx:id="backButton" text="← 返回" onAction="#handleBack"
                    styleClass="header-btn"/>
            <Label text="👤 个人信息" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="usernameLabel" text="用户名" styleClass="header-user"/>
            <Label fx:id="roleLabel" text="学生" 
                   style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; 
                          -fx-padding: 5 12; -fx-background-radius: 12; -fx-font-size: 12px;"/>
        </HBox>
    </top>
    
    <!-- 中间内容区 -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="25" styleClass="content">
                
                <!-- 基本信息卡片 -->
                <VBox spacing="20" styleClass="card">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="📋 基本信息" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="statusLabel" text="在住" styleClass="status-badge,success"/>
                    </HBox>
                    
                    <GridPane vgap="20" hgap="30">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="120"/>
                            <ColumnConstraints minWidth="200" prefWidth="280"/>
                            <ColumnConstraints minWidth="100" prefWidth="120"/>
                            <ColumnConstraints minWidth="200" prefWidth="280"/>
                        </columnConstraints>
                        
                        <!-- 第一行 -->
                        <Label text="学号" GridPane.rowIndex="0" GridPane.columnIndex="0" 
                               styleClass="label-secondary"/>
                        <TextField fx:id="studentNoField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <Label text="姓名" GridPane.rowIndex="0" GridPane.columnIndex="2"
                               styleClass="label-secondary"/>
                        <TextField fx:id="realNameField" GridPane.rowIndex="0" GridPane.columnIndex="3"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <!-- 第二行 -->
                        <Label text="性别" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               styleClass="label-secondary"/>
                        <ComboBox fx:id="genderCombo" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                  disable="true"/>
                        
                        <Label text="联系电话" GridPane.rowIndex="1" GridPane.columnIndex="2"
                               styleClass="label-secondary"/>
                        <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="3"
                                   promptText="请输入联系电话" styleClass="input-field"/>
                        
                        <!-- 第三行 -->
                        <Label text="院系" GridPane.rowIndex="2" GridPane.columnIndex="0"
                               styleClass="label-secondary"/>
                        <TextField fx:id="departmentField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <Label text="专业" GridPane.rowIndex="2" GridPane.columnIndex="2"
                               styleClass="label-secondary"/>
                        <TextField fx:id="majorField" GridPane.rowIndex="2" GridPane.columnIndex="3"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <!-- 第四行 -->
                        <Label text="班级" GridPane.rowIndex="3" GridPane.columnIndex="0"
                               styleClass="label-secondary"/>
                        <TextField fx:id="classNameField" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <Label text="年级" GridPane.rowIndex="3" GridPane.columnIndex="2"
                               styleClass="label-secondary"/>
                        <TextField fx:id="gradeField" GridPane.rowIndex="3" GridPane.columnIndex="3"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                    </GridPane>
                </VBox>
                
                <!-- 宿舍信息卡片 -->
                <VBox spacing="20" styleClass="card">
                    <Label text="🏠 宿舍信息" styleClass="card-title"/>
                    
                    <GridPane vgap="20" hgap="30">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="120"/>
                            <ColumnConstraints minWidth="200" prefWidth="280"/>
                            <ColumnConstraints minWidth="100" prefWidth="120"/>
                            <ColumnConstraints minWidth="200" prefWidth="280"/>
                        </columnConstraints>
                        
                        <Label text="宿舍号" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               styleClass="label-secondary"/>
                        <TextField fx:id="roomNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <Label text="床位号" GridPane.rowIndex="0" GridPane.columnIndex="2"
                               styleClass="label-secondary"/>
                        <TextField fx:id="bedNumberField" GridPane.rowIndex="0" GridPane.columnIndex="3"
                                   style="-fx-background-color: #edf2f7;" editable="false"/>
                        
                        <Label text="入住日期" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               styleClass="label-secondary"/>
                        <Label fx:id="checkInDateLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               text="未设置" style="-fx-text-fill: #2d3748; -fx-font-size: 14px;"/>
                    </GridPane>
                </VBox>
                
                <!-- 提示信息 -->
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #fffaf0; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ed8936; -fx-border-radius: 8; -fx-border-width: 1;">
                    <Label text="💡" style="-fx-font-size: 16px;"/>
                    <Label text="提示：灰色背景的字段为只读，由管理员维护。您只能修改联系电话和性别。" 
                           style="-fx-text-fill: #744210; -fx-font-size: 13px;"/>
                </HBox>
                
            </VBox>
        </ScrollPane>
    </center>
    
    <!-- 底部按钮栏 -->
    <bottom>
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
            <Button fx:id="editButton" text="✏️ 编辑信息" onAction="#handleEdit" styleClass="btn-primary"/>
            <Button fx:id="saveButton" text="💾 保存" onAction="#handleSave" visible="false" styleClass="btn-success"/>
            <Button fx:id="cancelButton" text="❌ 取消" onAction="#handleCancel" visible="false" styleClass="btn-secondary"/>
        </HBox>
    </bottom>
</BorderPane>
