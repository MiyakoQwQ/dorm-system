<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.client.controller.ProfileController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- 顶部标题栏 -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2196F3; -fx-padding: 15;">
            <Button fx:id="backButton" text="← 返回" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="个人信息" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="usernameLabel" text="用户名" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label fx:id="roleLabel" text="学生" 
                   style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; 
                          -fx-padding: 5 10; -fx-background-radius: 3;"/>
        </HBox>
    </top>
    
    <!-- 中间内容区 -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;">
                
                <!-- 基本信息卡片 -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; 
                                           -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <Label text="基本信息" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    
                    <GridPane vgap="15" hgap="20">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints minWidth="200" prefWidth="250"/>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints minWidth="200" prefWidth="250"/>
                        </columnConstraints>
                        
                        <!-- 第一行 -->
                        <Label text="学号：" GridPane.rowIndex="0" GridPane.columnIndex="0" 
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="studentNoField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <Label text="姓名：" GridPane.rowIndex="0" GridPane.columnIndex="2"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="realNameField" GridPane.rowIndex="0" GridPane.columnIndex="3"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <!-- 第二行 -->
                        <Label text="性别：" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666;"/>
                        <ComboBox fx:id="genderCombo" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                  style="-fx-background-color: #f0f0f0;" disable="true"/>
                        
                        <Label text="联系电话：" GridPane.rowIndex="1" GridPane.columnIndex="2"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="3"
                                   promptText="请输入联系电话"/>
                        
                        <!-- 第三行 -->
                        <Label text="院系：" GridPane.rowIndex="2" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="departmentField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <Label text="专业：" GridPane.rowIndex="2" GridPane.columnIndex="2"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="majorField" GridPane.rowIndex="2" GridPane.columnIndex="3"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <!-- 第四行 -->
                        <Label text="班级：" GridPane.rowIndex="3" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="classNameField" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <Label text="年级：" GridPane.rowIndex="3" GridPane.columnIndex="2"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="gradeField" GridPane.rowIndex="3" GridPane.columnIndex="3"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                    </GridPane>
                </VBox>
                
                <!-- 宿舍信息卡片 -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25;
                                           -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <Label text="宿舍信息" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    
                    <GridPane vgap="15" hgap="20">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints minWidth="200" prefWidth="250"/>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints minWidth="200" prefWidth="250"/>
                        </columnConstraints>
                        
                        <Label text="宿舍号：" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="roomNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <Label text="床位号：" GridPane.rowIndex="0" GridPane.columnIndex="2"
                               style="-fx-text-fill: #666;"/>
                        <TextField fx:id="bedNumberField" GridPane.rowIndex="0" GridPane.columnIndex="3"
                                   style="-fx-background-color: #f0f0f0;" editable="false"/>
                        
                        <Label text="入住日期：" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666;"/>
                        <Label fx:id="checkInDateLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               text="未设置" style="-fx-text-fill: #333; -fx-padding: 5 0;"/>
                        
                        <Label text="状态：" GridPane.rowIndex="1" GridPane.columnIndex="2"
                               style="-fx-text-fill: #666;"/>
                        <Label fx:id="statusLabel" GridPane.rowIndex="1" GridPane.columnIndex="3"
                               text="在住" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-padding: 5 0;"/>
                    </GridPane>
                </VBox>
                
                <!-- 提示信息 -->
                <Label text="提示：灰色背景的字段为只读，由管理员维护。您只能修改联系电话。" 
                       style="-fx-text-fill: #999; -fx-font-size: 12px;"/>
                
            </VBox>
        </ScrollPane>
    </center>
    
    <!-- 底部按钮栏 -->
    <bottom>
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 20; -fx-background-color: white;">
            <Button fx:id="editButton" text="编辑信息" onAction="#handleEdit"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; 
                           -fx-font-size: 14px; -fx-padding: 10 30; -fx-background-radius: 5;"/>
            <Button fx:id="saveButton" text="保存" onAction="#handleSave" visible="false"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-padding: 10 30; -fx-background-radius: 5;"/>
            <Button fx:id="cancelButton" text="取消" onAction="#handleCancel" visible="false"
                    style="-fx-background-color: #f0f0f0; -fx-text-fill: #666;
                           -fx-font-size: 14px; -fx-padding: 10 30; -fx-background-radius: 5;"/>
        </HBox>
    </bottom>
</BorderPane>
